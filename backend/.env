# ============================================
# Bank Statement Converter — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/sConverter?replicaSet=rs0

# JWT
JWT_SECRET=hello,i'm joseph mario
JWT_EXPIRES_IN=1d

# CORS — Frontend URL (production)
FRONTEND_URL=http://localhost:5173

# File uploads
MAX_FILE_SIZE=5242880  # 5MB in bytes

# Admin credentials (hardcoded fallback)
ADMIN_USERNAME=SystemAdmin
ADMIN_PASSWORD=getreadyforproductionandfight

# Admin user for create-admin script
ADMIN_EMAIL=admin@admin.com
ADMIN_NAME=System Administrator
